# Source (bundled by esbuild)
src/
esbuild.mjs
tsconfig.json

# Development — exclude node_modules except native/external modules needed at runtime
node_modules/
!node_modules/ssh2/
!node_modules/ssh2/**
!node_modules/cpu-features/
!node_modules/cpu-features/**
!node_modules/better-sqlite3/
!node_modules/better-sqlite3/**
*.tsbuildinfo
.vscode/

# Tests
**/__tests__/
**/*.test.ts
**/*.spec.ts

# Config
.eslintrc.json
.prettierrc

# Sourcemaps (production)
dist/**/*.map
