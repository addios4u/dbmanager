{
  "name": "dbmanager",
  "displayName": "DB Manager",
  "description": "Database management tool for VS Code - MySQL, MariaDB, PostgreSQL, SQLite, Redis",
  "private": true,
  "version": "1.0.0",
  "publisher": "addios4u",
  "packageManager": "pnpm@10.26.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/addios4u/dbmanager.git"
  },
  "keywords": [
    "database",
    "mysql",
    "mariadb",
    "postgresql",
    "sqlite",
    "redis",
    "sql",
    "vscode-extension",
    "dbeaver",
    "navicat"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @dbmanager/shared build && pnpm --filter @dbmanager/webview-ui build && pnpm --filter ./packages/extension build",
    "dev": "concurrently \"pnpm --filter @dbmanager/shared build --watch\" \"pnpm --filter @dbmanager/webview-ui dev\" \"pnpm --filter ./packages/extension watch\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @dbmanager/shared typecheck && pnpm --filter @dbmanager/webview-ui typecheck && pnpm --filter ./packages/extension typecheck",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"packages/*/src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "rebuild:sqlite": "npx @electron/rebuild --version 39.4.0 --module-dir node_modules/.pnpm/better-sqlite3@12.6.2/node_modules/better-sqlite3 --only better-sqlite3",
    "package": "pnpm build && mkdir -p out && cd packages/extension && cp ../../LICENSE . && pnpm exec vsce package --no-dependencies -o ../../out/dbmanager-$npm_package_version.vsix && rm LICENSE"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ssh2",
      "cpu-features",
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/l10n-dev": "^0.0.35",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
